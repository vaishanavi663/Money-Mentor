# Base URL for the API (with or without trailing `/api` — the client normalizes it).
#
# Local dev — use frontend/.env.local (gitignored), e.g.:
#   VITE_API_URL=http://localhost:5000
#
# Same-origin via Vite dev proxy:
#   VITE_API_URL=/api
#
# Production (Vercel): committed frontend/.env.production points at Render.
# If you add frontend/.env.local, it overrides .env.production even for `vite build` locally.
# On Vercel (no .env.local), the production URL is used. You can still set VITE_API_URL in Vercel env to override.
VITE_API_URL=http://localhost:5000
