# Must end with /api — the client calls /profile, /stats, /mf/top, etc. on top of this base.
#
# Option A — direct to backend (run `npm run server` in another terminal):
#   VITE_API_URL=http://localhost:4000/api
#
# Option B — same-origin via Vite proxy (vite.config.ts proxies /api → :4000):
#   VITE_API_URL=/api
VITE_API_URL=http://localhost:4000/api
