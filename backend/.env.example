PORT=4000
JWT_SECRET=replace-with-a-long-random-secret

# Optional on Render: restrict browser origins (comma-separated). If unset, all origins are allowed.
# Example after you deploy the frontend on Vercel:
# CORS_ORIGIN=https://your-app.vercel.app,https://www.yourdomain.com
# For Vercel preview URLs (*.vercel.app), add:
# CORS_ALLOW_VERCEL_PREVIEWS=true

# Option A: single URL (e.g. Neon, Supabase, Railway, or local)
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/finance_management

# Option B: separate fields (local Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_management
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
